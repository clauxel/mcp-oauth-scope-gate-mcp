{
  "name": "mcpoauthscopegate",
  "title": "MCP OAuth Scope Gate",
  "description": "Inspect MCP server scopes, score consent risk, request human approval, and return signed scope receipts before an agent proceeds.",
  "version": "1.0.0",
  "websiteUrl": "https://mcpoauthscopegate.clauxel.com/",
  "documentationUrl": "https://mcpoauthscopegate.clauxel.com/mcp/",
  "endpointUrl": "https://mcpoauthscopegate.clauxel.com/mcp",
  "transport": "streamable-http",
  "authentication": {
    "type": "bearer",
    "required": true,
    "header": "Authorization",
    "format": "Bearer <paid-token>"
  },
  "paidAccess": {
    "required": true,
    "checkoutUrl": "https://mcpoauthscopegate.clauxel.com/api/agent-checkout",
    "tokenStatusUrl": "https://mcpoauthscopegate.clauxel.com/api/mcp-token/status",
    "tokenClaimUrl": "https://mcpoauthscopegate.clauxel.com/api/mcp-token/claim",
    "defaultPlan": "team",
    "pricing": [
      {
        "id": "solo",
        "name": "Solo",
        "monthlyUsd": 39
      },
      {
        "id": "team",
        "name": "Team",
        "monthlyUsd": 129
      },
      {
        "id": "enterprise",
        "name": "Enterprise",
        "monthlyUsd": 349
      }
    ]
  },
